{
  "name": "readslot",
  "version": "0.9.0",
  "description": "Private reading queue and user-confirmed Google Calendar scheduler.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24 <27",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build && vite build --config vite.content.config.ts && node --env-file-if-exists=.env.local scripts/generate-manifest.mjs",
    "build:release": "vite build --mode production && vite build --config vite.content.config.ts --mode production && node scripts/generate-manifest.mjs --release && node scripts/validate-manifest.mjs --release",
    "package": "pnpm build:release && node scripts/package-release.mjs",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm validate:manifest"
  },
  "dependencies": {
    "@mozilla/readability": "0.6.0",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "date-fns-tz": "3.2.0",
    "dexie": "4.4.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/chrome": "0.2.2",
    "@types/mozilla__readability": "0.4.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fake-indexeddb": "6.2.5",
    "fast-check": "4.9.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
